{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/analytics.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/analytics",
      "dest": "api/analytics.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts",
      "headers": {
        "X-Content-Type-Options": "nosniff"
      }
    }
  ]
}
