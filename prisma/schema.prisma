generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model comodos {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pavimento_id     String             @db.Uuid
  apartamento_id   String?            @db.Uuid
  preco_tipo_id    String?            @db.Uuid
  tipo             tipo_comodo
  nome             String?
  parede1_m2       Decimal            @default(0) @db.Decimal(8, 2)
  parede2_m2       Decimal            @default(0) @db.Decimal(8, 2)
  parede3_m2       Decimal            @default(0) @db.Decimal(8, 2)
  parede4_m2       Decimal            @default(0) @db.Decimal(8, 2)
  teto_m2          Decimal            @default(0) @db.Decimal(8, 2)
  etapa_atual      etapa_processo?    @default(massa_parede)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  pavimentos       pavimentos         @relation(fields: [pavimento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  apartamentos     apartamentos?      @relation(fields: [apartamento_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  preco_tipos      preco_tipos?       @relation(fields: [preco_tipo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model compras {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item       String
  quantidade Int       @default(1)
  valor      Decimal   @db.Decimal(10, 2)
  status     String    @default("pendente")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model etapa_progresso {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  comodo_id  String         @db.Uuid
  etapa      etapa_processo
  valor_pago Decimal        @default(0) @db.Decimal(10, 2)
  concluida  Boolean        @default(false)
  created_at DateTime?      @default(now()) @db.Timestamptz(6)

  @@unique([comodo_id, etapa])
}

model funcionarios {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String
  cpf           String?   @unique
  cargo         String
  salario       Decimal?  @db.Decimal(10, 2)
  data_admissao DateTime? @db.Date
  status        String    @default("ativo")
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model lancamentos {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  descricao  String
  valor      Decimal   @db.Decimal(10, 2)
  tipo       String
  categoria  String?
  data       DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model obra_precos {
  id       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obra_id  String         @db.Uuid
  etapa    etapa_processo
  preco_m2 Decimal        @default(0) @db.Decimal(10, 2)
  obras    obras          @relation(fields: [obra_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([obra_id, etapa])
}

model preco_tipos {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obra_id      String              @db.Uuid
  nome         String
  created_at   DateTime?           @default(now()) @db.Timestamptz(6)
  obras        obras               @relation(fields: [obra_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  precos       preco_tipo_precos[]
  comodos      comodos[]
  apartamentos apartamentos[]
  pavimentos   pavimentos[]
}

model preco_tipo_precos {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  preco_tipo_id String         @db.Uuid
  etapa         etapa_processo
  preco_m2      Decimal        @default(0) @db.Decimal(10, 2)
  preco_tipos   preco_tipos    @relation(fields: [preco_tipo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([preco_tipo_id, etapa])
}

model obras {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome              String
  local             String
  empreiteira       String?
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  obra_precos       obra_precos[]
  pavimentos        pavimentos[]
  apartamento_tipos apartamento_tipos[]
  preco_tipos       preco_tipos[]
}

model orcamentos {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo      String
  descricao   String?
  valor_total Decimal   @db.Decimal(10, 2)
  status      String    @default("rascunho")
  validade    DateTime? @db.Date
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model pavimentos {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obra_id         String         @db.Uuid
  preco_tipo_id   String?        @db.Uuid
  nome            String
  numero          Int
  tipo            String         @default("pavimento")
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  comodos         comodos[]
  apartamentos    apartamentos[]
  obras           obras          @relation(fields: [obra_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  preco_tipos     preco_tipos?   @relation(fields: [preco_tipo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([obra_id, numero])
}

model apartamento_tipos {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obra_id      String         @db.Uuid
  nome         String
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  obras        obras          @relation(fields: [obra_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  apartamentos apartamentos[]
}

model apartamentos {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pavimento_id      String             @db.Uuid
  tipo_id           String?            @db.Uuid
  preco_tipo_id     String?            @db.Uuid
  nome              String?
  numero            Int?
  created_at        DateTime?          @default(now()) @db.Timestamptz(6)
  pavimentos        pavimentos         @relation(fields: [pavimento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  apartamento_tipos apartamento_tipos? @relation(fields: [tipo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  preco_tipos       preco_tipos?       @relation(fields: [preco_tipo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  comodos           comodos[]
}

enum etapa_processo {
  massa_parede
  massa_teto
  lixacao
  pintura
  acabamento
}

enum tipo_comodo {
  sala
  quarto
  banheiro
  suite
  varanda
  lavatorio
  circulacao
  escritorio
  area_tecnica
  escada
  corredor
  casa_maquinas
  casa_exaustao
  estacionamento
  garagem
  deposito
  area_lazer
}
